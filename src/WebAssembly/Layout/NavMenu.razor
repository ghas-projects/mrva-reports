        Icon="@Icons.Material.Outlined.Home" 
        Href="/"
        Match="NavLinkMatch.All">
        @ScreenText.Home
    </MudNavLink>

    <MudNavLink 
        Icon="@Icons.Material.Outlined.Code"
        Href="/repo"
        Match="NavLinkMatch.Prefix">
        @ScreenText.Repositories
