@page "/weather"

@using MRVA.Reports.Data

<PageTitle>Weather</PageTitle>

<h1>Weather</h1>

<p>This component demonstrates fetching data from the server.</p>

@if (Forecasts == null)
{
    <MudProgressLinear Color="Color.Default" Indeterminate="true" />
    return;
}

<MudDataGrid T="WeatherForecast" MultiSelection="true" Items="@Forecasts" SortMode="SortMode.Multiple" Filterable="true" QuickFilter="@_quickFilter"
    Hideable="true" RowClick="@RowClicked" RowContextMenuClick="RowRightClicked" SelectedItemsChanged="@SelectedItemsChanged">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Forecast</MudText>
        <MudSpacer />
        <MudTextField @bind-Value="_searchString" Placeholder="@ScreenText.Search" Adornment="Adornment.Start" Immediate="true"
            AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
    </ToolBarContent>
    <Columns>
        <PropertyColumn Property="x => x.Date" Title="Date" Sortable="false" Filterable="false" />
        <PropertyColumn Property="x => x.TemperatureC" Title="Temp. (C)" />
        <PropertyColumn Property="x => x.TemperatureF" Title="Temp. (F)" />
        <PropertyColumn Property="x => x.Summary" SortBy="@_sortBy" />
    </Columns>
    <PagerContent>
        <MudDataGridPager T="WeatherForecast" />
    </PagerContent>
</MudDataGrid>

<div class="d-flex flex-wrap mt-4">
    <MudSwitch @bind-Value="@_sortNameByLength" Color="Color.Primary">Sort Name Column By Length</MudSwitch>
</div>

<MudExpansionPanels Style="flex:1">
    <MudExpansionPanel Text="Show Events">
        @foreach (var message in _events)
        {
            <MudText Typo="@Typo.body2">@message</MudText>
        }
        @if(_events.Count > 0) 
        {
            <div class="d-flex">
                <MudSpacer/>
                <MudButton Class="mt-3" ButtonType="ButtonType.Button" Variant="Variant.Filled" OnClick="@(() => _events.Clear())">Clear</MudButton>
            </div>
        }
    </MudExpansionPanel>
</MudExpansionPanels>
